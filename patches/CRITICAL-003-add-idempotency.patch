CREATE UNIQUE INDEX idx_transactions_idempotency_key ON transactions(idempotency_key);

-- Backfill existing transactions with UUID based on ID
UPDATE transactions SET idempotency_key = CONCAT('legacy-', id) WHERE idempotency_key IS NULL;
