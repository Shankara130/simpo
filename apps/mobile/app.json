{
  "name": "simpo",
  "displayName": "Simpo",
  "expo": {
    "name": "simpo",
    "slug": "simpo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Required for offline transaction storage and network state detection"
      }
    },
    "android": {
      "package": "com.simpo.pos",
      "permissions": [
        "INTERNET",
        "USB_PERMISSION",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "ACCESS_WIFI_STATE",
        "ACCESS_NETWORK_STATE"
      ]
    }
  }
}
