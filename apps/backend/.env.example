# ===========================================
# Go REST API Boilerplate - Environment Variables
# ===========================================
# 
# Copy this file to .env and set your values
# 
# CONFIGURATION PRIORITY (highest to lowest):
# 1. Environment variables (.env file) - THIS FILE
# 2. Environment-specific config (config.production.yaml, etc.)
# 3. Base configuration (config.yaml)
#
# 📋 For ALL available configuration options, see: configs/config.yaml
# 🔧 Most defaults are in config files - only override what you need here
#
# ===========================================

# ===========================================
# Go REST API Version (for Docker Compose)
# ===========================================
VERSION=2.0.0

# ===========================================
# Application version
# ===========================================
APP_VERSION=1.0.0

# ===========================================
# ENVIRONMENT SELECTION
# ===========================================
APP_ENVIRONMENT=development        # development | staging | production

# ===========================================
# ⚠️  SECURITY: JWT SECRET (REQUIRED)
# =========================================== 
# Security Requirements:
# Minimum 32 characters (64+ for production)
#
# Auto-generation (recommended):
#   make quick-start          # Automatically generates if missing
#   make generate-jwt-secret  # Manual generation with examples
#
JWT_SECRET=simpo_jwt_secret_key_min_32_chars_for_production_please_change

# Token expiration (Story 1.5, NFR-SEC-002: 8-hour session timeout)
# JWT_ACCESS_TOKEN_TTL=8h          # Access token TTL (8 hours per pharmacy requirements)
# JWT_REFRESH_TOKEN_TTL=168h       # Refresh token TTL (7 days)

# ===========================================
# DATABASE (from project root docker-compose.yml)
# ===========================================
# Start services: docker-compose up -d (from project root)
DATABASE_HOST=localhost     # PostgreSQL service from docker-compose
DATABASE_PORT=5432          # Exposed port
DATABASE_USER=postgres      # Docker Compose default
DATABASE_PASSWORD=postgres  # Docker Compose default (development only)
DATABASE_NAME=simpo_db      # simpo database name
DATABASE_SSLMODE=disable    # Local development without SSL

# ===========================================
# REDIS (from project root docker-compose.yml)
# ===========================================
# Start services: docker-compose up -d (from project root)
REDIS_HOST=localhost        # Redis service from docker-compose
REDIS_PORT=6379             # Exposed port
REDIS_PASSWORD=             # Empty password for development (localhost only)

# Connection Pooling
DB_MAX_OPEN_CONNECTIONS=25         # Maximum open connections
DB_MAX_IDLE_CONNECTIONS=5          # Maximum idle connections
DB_CONNECTION_MAX_LIFETIME=300     # Connection lifetime in seconds (5 minutes = 300 seconds)

# ===========================================
# COMMON OVERRIDES (optional - uncomment to use)
# ===========================================
# SERVER_PORT=8080                 # Override server port
# LOGGING_LEVEL=debug              # Override for verbose logging

# ===========================================
# RATE LIMITING CONFIGURATION
# ===========================================
RATELIMIT_ENABLED=true
RATELIMIT_REQUESTS=100
RATELIMIT_WINDOW=1m

# ===========================================
# CORS CONFIGURATION (Story 9.4)
# ===========================================
# CORS enables cross-origin requests from web dashboard
# SECURITY: Never use wildcard origins (*) in production
CORS_ENABLED=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006,https://admin.simpo.com
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Requested-With
CORS_MAX_AGE=86400

# ===========================================
# STRUCTURED LOGGING CONFIGURATION (Story 9.5)
# ===========================================
# Enhanced logging with caller info, sensitive data redaction, and business events
LOGGING_LEVEL=info                                    # Log level: debug, info, warn, error
LOGGING_REDACT_ENABLED=true                            # Enable sensitive data redaction (passwords, tokens, etc.)
LOGGING_INCLUDE_CALLER=false                          # Include caller information (file:line) in logs
LOGGING_BUSINESS_EVENTS=true                           # Enable business event logging for audit trail
# LOGGING_REDACTpatterns=password,token,secret,authorization,cookie

# ===========================================
# CONTAINER NAMES (for docker-compose)
# ===========================================
APP_CONTAINER_NAME=go_api_app
DATABASE_CONTAINER_NAME=go_api_db
APP_CONTAINER_NAME_PROD=go_api_app_prod
DATABASE_CONTAINER_NAME_PROD=go_api_db_prod

# ===========================================
# HEALTH CHECK CONFIGURATION (for docker-compose)
# ===========================================
HEALTH_CHECK_INTERVAL=15s
HEALTH_CHECK_TIMEOUT=5s
HEALTH_CHECK_RETRIES=5
HEALTH_CHECK_START_PERIOD=15s
