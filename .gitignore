# ===========================================
# simpo Monorepo - Root .gitignore
# ===========================================

# ===========================================
# OS & Editor Files
# ===========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ===========================================
# Environment Variables & Secrets
# ===========================================
.env
.env.local
.env.*.local
*.pem
*.key
*.cert
secrets/
credentials/

# ===========================================
# Dependencies
# ===========================================
node_modules/
vendor/
bower_components/

# ===========================================
# Build Outputs
# ===========================================
build/
dist/
out/
target/
bin/
tmp/
*.log

# ===========================================
# Mobile (React Native)
# ===========================================
# Xcode
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata
*.xccheckout
*.moved-aside
DerivedData
*.hmap
*.ipa
*.xcuserstate
**/.xcode.env.local

# Android/IntelliJ
.gradle
local.properties
*.iml
*.hprof
.cxx/
*.keystore
!debug.keystore
.kotlin/

# Fastlane
**/fastlane/report.xml
**/fastlane/Preview.html
**/fastlane/screenshots
**/fastlane/test_output

# Bundle artifact
*.jsbundle

# CocoaPods
**/Pods/
/vendor/bundle/

# Metro health check
.metro-health-check*

# ===========================================
# Backend (Go)
# ===========================================
# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary
*.test

# Coverage
*.out
coverage.txt
coverage.html

# Go workspace
go.work

# Generated docs (Swagger)
**/api/docs/docs.go
**/api/docs/swagger.json
**/api/docs/swagger.yaml

# Air live reload
.air.toml

# ===========================================
# Web (Next.js)
# ===========================================
.next/
out/
build/
swc/

# ===========================================
# Database & Data
# ===========================================
*.db
*.sqlite
*.sqlite3
postgres_data/
redis_data/
data/

# ===========================================
# Testing & Coverage
# ===========================================
coverage/
.nyc_output/
*.lcov

# ===========================================
# Logs
# ===========================================
*.log
logs/
npm-debug.log
yarn-error.log

# ===========================================
# Yarn
# ===========================================
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# ===========================================
# Documentation Generated
# ===========================================
_docs/

# ===========================================
# Backup Files
# ===========================================
*.bak
*.backup
*.tmp
backups/

# ===========================================
# Docker
# ===========================================
docker-compose.override.yml
